build*/
build-simplify/

# Cadence user preferences, history, and session state
cadence/.cadence/
cadence/perf/
cadence/drc/
cadence/lvs/
.cadence/perf/

# Cadence log files
cadence/libManager.log
cadence/*.log

# Cadence generated thumbnails (auto-regenerated on open)
**/thumbnail_*.png

# Cadence lock files (created during active sessions)
**/*.lck
**/*cdslck*
**/cdslck/

# Ignore all log, cache, and tmp files
*.tmp*
*.log
*.log.*
logs*/
*oacache*

# Verilator flow generated files
flow/obj_dir/
flow/*-pickled.v

# Processor flow generated tool output
flow/alib/
flow/work/
flow/csrc/
flow/*.daidir/
flow/post-synth.*
flow/*.rpt
flow/proc2_vcs
flow/proc2_ffglsim
flow/ucli.key
