build*/
build-simplify/

# Cadence user preferences, history, and session state
cadence/.cadence/
cadence/perf/
cadence/drc/
cadence/lvs/

# Cadence log files
cadence/libManager.log
cadence/*.log

# Cadence generated thumbnails (auto-regenerated on open)
**/thumbnail_*.png

# Cadence lock files (created during active sessions)
**/*.lck
**/*cdslck*
**/cdslck/

# Ignore all log and tmp files
*.tmp*
*log*
