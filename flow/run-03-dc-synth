#!/usr/bin/env bash
#=========================================================================
# run-03-dc-synth
#=========================================================================

# Stop on error and echo all commands

set -euo pipefail

# Determine RUNDIR

RUNDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$RUNDIR"

RTL_FILE="ProcCtrl2-pickled.v"

if [[ ! -f "$RTL_FILE" ]]; then
  echo "ERROR: $RTL_FILE not found. Run ./run-01-verilator first."
  exit 1
fi

if [[ -z "${TSMC_180NM:-}" ]]; then
  echo "ERROR: TSMC_180NM is not set."
  exit 1
fi

# Set alib
rm -rf alib work post-synth.ddc post-synth.v post-synth.sdc \
       timing.rpt area.rpt resources.rpt run.log
mkdir -p alib
cp -srf "${TSMC_180NM}/stdcells.alib/"* alib

# Run DC
dc_shell-xg-t -f run.tcl | tee run.log
