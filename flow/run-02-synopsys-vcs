#!/usr/bin/env bash
#=========================================================================
# 02-synopsys-vcs
#=========================================================================

set -euo pipefail

# Colors

RED="\e[31m"
GREEN="\e[32m"
RESET="\e[0m"

# Determine RUNDIR

RUNDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$RUNDIR"

DESIGN_NAME="Proc2"
TEST_NAME="proc2_vcs"
TEST_UTILS="../v/test/test-utils.v"
TEST_MEMORY="../v/test/TestMemory.v"
TESTBENCH_PICKLED="Proc2-testbench-pickled.v"
TOP_PICKLED="Proc2-top-pickled.v"
CTRL_RTL="${CTRL_RTL:-ProcCtrl2-pickled.v}"

for input in "$TEST_UTILS" "$TEST_MEMORY" "$TESTBENCH_PICKLED" "$TOP_PICKLED" "$CTRL_RTL"; do
  if [[ ! -f "$input" ]]; then
    echo "ERROR: $input not found. Run ./run-01-verilator first."
    exit 1
  fi
done

rm -rf "$TEST_NAME" "$TEST_NAME.daidir" "$TEST_NAME.log" run.log

echo "CMD: vcs -top Top -o $TEST_NAME $TEST_UTILS $TEST_MEMORY $TESTBENCH_PICKLED $TOP_PICKLED $CTRL_RTL"
vcs -sverilog -xprop=tmerge -override_timescale=1ns/1ps \
  +incdir+../v \
  -top Top \
  -o "$TEST_NAME" \
  "$TEST_UTILS" \
  "$TEST_MEMORY" \
  "$TESTBENCH_PICKLED" \
  "$TOP_PICKLED" \
  "$CTRL_RTL" | tee "$TEST_NAME.log"

echo "CMD: ./$TEST_NAME"
./"$TEST_NAME" | tee -a "$TEST_NAME.log"

test_status=0
if grep -Eq "num_test_cases_passed = +[1-9][0-9]*" "$TEST_NAME.log" && \
   grep -Eq "num_test_cases_failed = +0" "$TEST_NAME.log"; then
  echo -e ">>>> [ ${GREEN}passed${RESET} ] $TEST_NAME" >> "$TEST_NAME.log"
else
  echo -e ">>>> [ ${RED}FAILED${RESET} ] $TEST_NAME" >> "$TEST_NAME.log"
  test_status=1
fi

echo "" > run.log
grep -h ">>>" "$TEST_NAME.log" | sed -e 's/>>>>//' >> run.log
echo "" >> run.log
cat run.log

exit "$test_status"
